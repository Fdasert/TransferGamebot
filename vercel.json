{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/webhook",     "dest": "/api/webhook.py"     },
    { "src": "/api/set_webhook", "dest": "/api/set_webhook.py" }
  ],
  "functions": {
    "api/webhook.py": {
      "maxDuration": 10
    },
    "api/set_webhook.py": {
      "maxDuration": 10
    }
  }
}
